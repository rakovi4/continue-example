{
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "jdtls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "plansDirectory": "./ProductSpecification/plans",
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "enableAllProjectMcpServers": false,
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-timing.sh\" dispatch 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-timing.sh\" return 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-timing.sh\" return_failure 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-timing.sh\" subagent_start 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{ bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-timing-smoke.sh\" && bash \"$CLAUDE_PROJECT_DIR/infrastructure/scripts/agent-timing-report-smoke.sh\"; } >/dev/null 2>&1 || printf '{\"systemMessage\":\"agent-timing smoke checks FAILED — timing instrumentation or aggregation may be broken; run: bash .claude/hooks/agent-timing-smoke.sh && bash infrastructure/scripts/agent-timing-report-smoke.sh\"}'",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-timing.sh\" subagent_stop 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
